# ========== 数据库：MySQL（远程示例） ==========
# 格式: mysql+asyncmy://用户:密码@host:port/库名?charset=utf8mb4
DATABASE_URL=mysql+asyncmy://用户名:密码@mysql7.sqlpub.com:3312/库名?charset=utf8mb4

# ========== Redis：远程免费（Upstash） ==========
# 必须用「Redis 协议 URL」，不是 REST 的 https 地址；Token/密码已包含在 URL 里，无需单独填。
# 获取：console.upstash.com → 选数据库 → Redis 连接方式 → 复制「Redis URL」
# 格式：rediss://default:密码@xxx.upstash.io:6379
REDIS_URL=
# Celery 用同一 Redis 即可（填同一串 Redis URL）
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ========== 向量库：Zilliz Cloud（免费） ==========
# 使用 Zilliz：https://zilliz.com.cn 创建 Serverless 集群，复制 URI 和 Token
VECTOR_DB_TYPE=zilliz
ZILLIZ_URI=https://你的集群.serverless.ali-cn-hangzhou.cloud.zilliz.com.cn
ZILLIZ_TOKEN=你的Token
ZILLIZ_COLLECTION_NAME=test_multi_context
ZILLIZ_DIM=1536
# 若改用 Qdrant，设 VECTOR_DB_TYPE=qdrant 并填下面两项
QDRANT_URL=
QDRANT_API_KEY=

# ========== MinIO：公网免费（无需注册） ==========
# MinIO Play 公开测试环境，勿存敏感数据
MINIO_ENDPOINT=play.min.io
MINIO_ACCESS_KEY=Q3AM3UQ867SPQQA43P2F
MINIO_SECRET_KEY=zuf+tfteSlswRu7BJ86wekitnifILbZam1KYY3TG
MINIO_SECURE=true
MINIO_BUCKET_NAME=rag-files

# ========== 应用密钥 ==========
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ========== AI 模型：阿里云 DashScope ==========
OPENAI_API_KEY=你的阿里云API_KEY
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-3-large
LLM_MODEL=qwen2-vl-plus

LOCAL_EMBEDDING_MODEL=m3e-base
LOCAL_LLM_MODEL=qwen2.5-7b
LOCAL_MODEL_BASE_URL=http://localhost:11434

MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=pdf,ppt,pptx,txt,xlsx,docx,jpeg,jpg,png,md,html,zip
STORAGE_TYPE=minio
MINIO_BUCKET_NAME=rag-files

